---
import Base from '../layouts/Base.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const maintainers = [
  { name: 'Jan Kurik', github: 'https://github.com/kurik' },
  { name: 'Ken McDonell', github: 'https://github.com/kmcdonell' },
  { name: 'Lauren Chilton', github: 'https://github.com/lmchilton' },
  { name: 'Marko Myllynen', github: 'https://github.com/myllynen' },
  { name: 'Nathan Scott', github: 'https://github.com/natoscott' },
  { name: 'Paul Smith', github: 'https://github.com/tallpsmith' },
  { name: 'Sam Feifer', github: 'https://github.com/sfeifer' },
  { name: 'Will Cohen', github: 'https://github.com/wcohen' },
];
---

<Base title="Team - Performance Co-Pilot">
  <Header />
  <!-- Hero Section -->
  <section class="relative py-20 overflow-hidden bg-gradient-to-b from-void via-space to-panel">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 2px, var(--color-data) 2px, var(--color-data) 3px); background-size: 100% 60px;"></div>
    </div>

    <div class="container relative z-10 px-6 mx-auto max-w-5xl">
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-6 tracking-tight">
        Mission <span class="text-contrail">Control</span>
      </h1>
      <p class="text-xl text-gray-300 max-w-2xl leading-relaxed">
        Performance Co-Pilot releases are coordinated by the core team.
      </p>
    </div>
  </section>

  <!-- Maintainers Grid -->
  <section class="py-20 bg-panel">
    <div class="container px-6 mx-auto max-w-6xl">
      <h2 class="text-3xl font-bold text-white mb-12 text-center">
        Core <span class="text-data">Maintainers</span>
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
        {maintainers.map((member) => (
          <a
            href={member.github}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative bg-instrument border border-gray-700 hover:border-data transition-all duration-300 overflow-hidden"
          >
            <!-- Instrument panel bezel effect -->
            <div class="absolute inset-0 border-2 border-transparent group-hover:border-data/20 pointer-events-none transition-all duration-300"></div>

            <!-- Scanline effect -->
            <div class="absolute inset-0 opacity-0 group-hover:opacity-30 transition-opacity duration-300 pointer-events-none" style="background: repeating-linear-gradient(0deg, transparent, transparent 2px, var(--color-data) 2px, var(--color-data) 3px); background-size: 100% 4px;"></div>

            <div class="relative p-6 text-center">
              <!-- GitHub icon using SVG -->
              <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-space border border-gray-600 group-hover:border-data flex items-center justify-center transition-all duration-300">
                <svg class="w-8 h-8 text-gray-400 group-hover:text-data transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                </svg>
              </div>

              <h3 class="text-lg font-semibold text-white mb-1">{member.name}</h3>
              <p class="text-sm text-gray-400 group-hover:text-data transition-colors duration-300 font-mono">
                @{member.github.split('/').pop()}
              </p>
            </div>

            <!-- Corner accent -->
            <div class="absolute top-0 right-0 w-8 h-8 border-t-2 border-r-2 border-contrail opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          </a>
        ))}
      </div>

      <!-- Community Section -->
      <div class="relative bg-gradient-to-br from-instrument to-space border border-gray-700 p-8 text-center overflow-hidden">
        <!-- Background grid -->
        <div class="absolute inset-0 opacity-5" style="background-image: linear-gradient(var(--color-data) 1px, transparent 1px), linear-gradient(90deg, var(--color-data) 1px, transparent 1px); background-size: 20px 20px;"></div>

        <div class="relative z-10">
          <p class="text-lg text-gray-300 mb-4">
            Bringing together the efforts of a fantastic
          </p>
          <a
            href="https://github.com/performancecopilot/pcp/graphs/contributors"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-data hover:text-white font-semibold text-xl transition-colors duration-300 group"
          >
            developer community
            <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
  /* Aviation-inspired hover glow */
  a[href^="https://github.com/"]:hover {
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.2), inset 0 0 40px rgba(0, 212, 255, 0.05);
  }
</style>
