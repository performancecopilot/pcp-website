---
import Base from '../../layouts/Base.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import YearNavigation from '../../components/ui/YearNavigation.astro';

const years = [
  { year: '2021', url: '/gsod/2021/ideas.html', status: 'completed' as const },
  { year: '2020', url: '/gsod/2020/ideas.html', status: 'completed' as const },
  { year: '2019', url: '/gsod/2019/ideas.html', status: 'completed' as const },
];
---

<Base title="Google Season of Docs - Performance Co-Pilot">
  <Header />

  <!-- Hero Section -->
  <section class="relative py-20 overflow-hidden bg-gradient-to-b from-void via-space to-panel">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 2px, var(--color-data) 2px, var(--color-data) 3px); background-size: 100% 60px;"></div>
    </div>

    <div class="container relative z-10 px-6 mx-auto max-w-5xl">
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-6 tracking-tight">
        Google <span class="text-contrail">Season of Docs</span>
      </h1>
      <p class="text-xl text-gray-300 max-w-2xl leading-relaxed">
        Performance Co-Pilot has participated in Google Season of Docs to improve
        documentation quality, create new guides, and make technical content more
        accessible to developers and users.
      </p>
    </div>
  </section>

  <!-- Year Selection -->
  <section class="py-20 bg-panel">
    <div class="container px-6 mx-auto max-w-5xl">
      <div class="bg-gradient-to-br from-instrument to-space border border-gray-700 p-8">
        <!-- Corner accent -->
        <div class="relative">
          <div class="absolute top-0 right-0 w-12 h-12 border-t-2 border-r-2 border-data/40"></div>

          <h2 class="text-3xl font-bold text-white mb-6">Select a Year</h2>
          <p class="text-gray-300 mb-8 leading-relaxed">
            Browse documentation projects from past Google Season of Docs programs.
            Each year features projects focused on improving PCP documentation,
            creating guides, and enhancing the developer experience.
          </p>

          <YearNavigation years={years} title="" />

          <div class="mt-8 pt-8 border-t border-gray-700">
            <h3 class="text-xl font-bold text-white mb-4">2021 Resources</h3>
            <p class="text-gray-300 mb-4 text-sm">
              The 2021 Season of Docs was structured differently as a single comprehensive project.
              View the complete proposal and case study:
            </p>
            <ul class="space-y-2 mb-6">
              <li>
                <a
                  href="/gsod/2021/proposal.html"
                  class="text-data hover:text-contrail transition-colors duration-200 flex items-center gap-2"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd" />
                  </svg>
                  <span>2021 Project Proposal</span>
                </a>
              </li>
              <li>
                <a
                  href="/gsod/2021/casestudy.html"
                  class="text-data hover:text-contrail transition-colors duration-200 flex items-center gap-2"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" />
                    <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd" />
                  </svg>
                  <span>2021 Case Study</span>
                </a>
              </li>
            </ul>

            <h3 class="text-xl font-bold text-white mb-4">Additional Resources</h3>
            <ul class="space-y-2">
              <li>
                <a
                  href="https://developers.google.com/season-of-docs"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-data hover:text-contrail transition-colors duration-200 flex items-center gap-2"
                >
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                  <span>Google Season of Docs Homepage</span>
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>
