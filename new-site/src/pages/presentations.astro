---

<Base title="Presentations - Performance Co-Pilot">
  <Header />
  <!-- Hero Section -->
  <section class="relative py-20 overflow-hidden bg-gradient-to-b from-void via-space to-panel">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 2px, var(--color-data) 2px, var(--color-data) 3px); background-size: 100% 60px;"></div>
    </div>

    <div class="container relative z-10 px-6 mx-auto max-w-5xl">
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-6 tracking-tight">
        Mission <span class="text-contrail">Archives</span>
      </h1>
      <p class="text-xl text-gray-300 max-w-2xl leading-relaxed">
        Various presentations from conferences and user groups, providing more details of the PCP architecture and features.
      </p>
    </div>
  </section>

  <!-- Presentations Timeline -->
  <section class="py-20 bg-panel">
    <div class="container px-6 mx-auto max-w-6xl">
      <div class="grid md:grid-cols-2 gap-12">
        {presentationsByYear.map((yearGroup) => (
          <div class="relative">
            <!-- Year Header -->
            <div class="sticky top-4 mb-8 z-10">
              <div class="inline-block bg-gradient-to-r from-contrail to-data px-6 py-2 border-l-4 border-contrail">
                <h2 class="text-2xl font-bold text-white font-mono">{yearGroup.year}</h2>
              </div>
            </div>

            <!-- Presentations List -->
            <div class="space-y-6">
              {yearGroup.presentations.map((presentation) => (
                <div class="group relative bg-gradient-to-br from-instrument to-space border border-gray-700 hover:border-data/50 p-6 transition-all duration-300 overflow-hidden">
                  <!-- Corner accent -->
                  <div class="absolute top-0 right-0 w-12 h-12 border-t-2 border-r-2 border-data/0 group-hover:border-data/40 transition-all duration-300"></div>

                  <!-- Scanline on hover -->
                  <div class="absolute inset-0 opacity-0 group-hover:opacity-10 transition-opacity duration-300 pointer-events-none" style="background: repeating-linear-gradient(0deg, transparent, transparent 2px, var(--color-data) 2px, var(--color-data) 3px); background-size: 100% 4px;"></div>

                  <div class="relative z-10">
                    <!-- Title -->
                    <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-data transition-colors duration-300">
                      {presentation.title}
                    </h3>

                    <!-- Date/Location -->
                    <p class="text-sm text-gray-400 mb-4 italic">{presentation.date}</p>

                    <!-- Links -->
                    <div class="flex flex-wrap gap-3">
                      {presentation.links.map((link) => (
                        <a
                          href={link.url}
                          target={link.url.startsWith('http') ? '_blank' : undefined}
                          rel={link.url.startsWith('http') ? 'noopener noreferrer' : undefined}
                          class="inline-flex items-center gap-2 px-3 py-1.5 bg-void border border-gray-600 hover:border-data text-gray-300 hover:text-white text-sm font-mono transition-all duration-300 group/link"
                        >
                          <!-- Icon based on link type -->
                          {link.label.toLowerCase().includes('video') ? (
                            <svg class="w-4 h-4 text-contrail" fill="currentColor" viewBox="0 0 20 20">
                              <path d="M2 6a2 2 0 012-2h6a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V6zM14.553 7.106A1 1 0 0014 8v4a1 1 0 00.553.894l2 1A1 1 0 0018 13V7a1 1 0 00-1.447-.894l-2 1z" />
                            </svg>
                          ) : link.label.toLowerCase().includes('photo') ? (
                            <svg class="w-4 h-4 text-data" fill="currentColor" viewBox="0 0 20 20">
                              <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd" />
                            </svg>
                          ) : (
                            <svg class="w-4 h-4 text-gray-400 group-hover/link:text-data transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                            </svg>
                          )}
                          <span>{link.label}</span>
                          {link.url.startsWith('http') && (
                            <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                            </svg>
                          )}
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Base>
