---
import Base from '../layouts/Base.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';

const pageTitle = "Documentation - Performance Co-Pilot";
---

<Base title={pageTitle}>
  <!-- Documentation Hero -->
  <section class="py-20 px-4 bg-gradient-to-b from-void to-space">
    <div class="container mx-auto max-w-4xl text-center">
      <h1 class="text-5xl md:text-6xl font-bold mb-8 text-white">
        Documentation
      </h1>
      <div class="flex flex-wrap gap-4 justify-center">
        <Button
          href="https://pcp.readthedocs.io/en/latest/HowTos/installation/index.html"
          variant="primary"
          external
        >
          Installation
        </Button>
        <Button
          href="https://pcp.readthedocs.io/en/latest/QG/QuickReferenceGuide.html"
          variant="secondary"
          external
        >
          Quick Reference Guide
        </Button>
      </div>
    </div>
  </section>

  <!-- Main Documentation Resources -->
  <section class="py-16 px-4">
    <div class="container mx-auto max-w-6xl">
      <div class="grid md:grid-cols-2 gap-12">
        <!-- Left Column: Main Resources -->
        <div class="space-y-8">
          <div>
            <h3 class="text-2xl font-bold mb-3 text-white">
              <a href="https://man7.org/linux/man-pages/dir_by_project.html#PCP" class="hover:text-data transition-colors">
                Man pages
              </a>
            </h3>
            <p class="text-gray-300">
              All of the manual pages for PCP tools and APIs
            </p>
          </div>

          <div>
            <h3 class="text-2xl font-bold mb-3 text-white">
              <a href="https://pcp.readthedocs.io" class="hover:text-data transition-colors">
                Guides
              </a>
            </h3>
            <p class="text-gray-300">
              Users and Administrators Guide, Programmers and REST API Guides
            </p>
          </div>

          <div>
            <h3 class="text-2xl font-bold mb-3 text-white">
              <a href="/slides/index.html" class="hover:text-data transition-colors">
                Slides
              </a>
            </h3>
            <p class="text-gray-300">
              An online presentation about PCP
            </p>
          </div>

          <div>
            <h3 class="text-2xl font-bold mb-3 text-white">
              <a href="presentations.html" class="hover:text-data transition-colors">
                Papers
              </a>
            </h3>
            <p class="text-gray-300">
              Reference papers and presentations we have permission to reproduce.
            </p>
          </div>

          <div>
            <h3 class="text-2xl font-bold mb-3 text-white">
              <a href="screenshots.html" class="hover:text-data transition-colors">
                Screenshots
              </a>
            </h3>
            <p class="text-gray-300">
              Screenshots from a handful of PCP GUI and console tools, and the more recent
              <a href="https://grafana-pcp.readthedocs.io/en/latest/screenshots.html" class="text-data hover:underline">
                Grafana PCP
              </a> plugin.
            </p>
          </div>
        </div>

        <!-- Right Column: Short Guides -->
        <div>
          <h3 class="text-2xl font-bold mb-6 text-white">Short Guides</h3>
          <ul class="space-y-3 text-gray-300">
            <li>
              <a href="https://pcp.readthedocs.io/en/latest/QG/UseCharts.html" class="text-data hover:underline">
                Using Charts
              </a>
            </li>
            <li>
              <a href="https://pcp.readthedocs.io/en/latest/QG/LoggingBasics.html" class="text-data hover:underline">
                Logging Basics
              </a>
            </li>
            <li>
              <a href="https://pcp.readthedocs.io/en/latest/QG/AutomatedReasoningBasics.html" class="text-data hover:underline">
                Automated Reasoning Basics
              </a>
            </li>
            <li>
              <a href="https://pcp.readthedocs.io/en/latest/QG/ConfigureAutomatedReasoning.html" class="text-data hover:underline">
                Configuring Automated Reasoning
              </a>
            </li>
            <li>
              <a href="https://pcp.readthedocs.io/en/latest/QG/AnalyzeLinuxContainers.html" class="text-data hover:underline">
                Analysis of Linux Containers
              </a>
            </li>
            <li>
              <a href="https://pcp.readthedocs.io/en/latest/QG/EncryptedConnections.html" class="text-data hover:underline">
                Encrypted Connections
              </a>
            </li>
            <li>
              <a href="https://pcp.readthedocs.io/en/latest/QG/AuthenticatedConnections.html" class="text-data hover:underline">
                Authenticated Connections
              </a>
            </li>
            <li>
              <a href="/papers/archive-interpolation.pdf" class="text-data hover:underline">
                Explaining Value Interpolation with PCP Archives
              </a>
            </li>
            <li>
              <a href="https://pcp.readthedocs.io/en/latest/QG/ImportData.html" class="text-data hover:underline">
                Importing data and creating PCP archives (C, Perl, Python)
              </a>
            </li>
            <li>
              <a href="https://pcp.readthedocs.io/en/latest/QG/Use3DViews.html" class="text-data hover:underline">
                Using 3D Views (experimental, source only)
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Blog Section -->
  <section class="py-16 px-4 bg-panel">
    <div class="container mx-auto max-w-4xl text-center">
      <h2 class="text-4xl font-bold mb-8 text-white">Blog</h2>
      <div class="flex flex-wrap gap-4 justify-center">
        <Button
          href="https://www.redhat.com/en/blog/visualizing-system-performance-rhel-8-using-performance-co-pilot-pcp-and-grafana-part-1"
          variant="ghost"
          external
        >
          PCP and Grafana (Part 1)
        </Button>
        <Button
          href="https://www.redhat.com/en/blog/visualizing-system-performance-rhel-8-using-performance-co-pilot-pcp-and-grafana-part-2"
          variant="ghost"
          external
        >
          PCP and Grafana (Part 2)
        </Button>
        <Button
          href="https://www.redhat.com/en/blog/visualizing-system-performance-rhel-8-part-3-kernel-metric-graphing-performance-co-pilot-grafana-and-bpftrace"
          variant="ghost"
          external
        >
          PCP and Grafana (Part 3)
        </Button>
        <Button
          href="https://www.redhat.com/en/blog/monitoring-ebpf-based-metrics"
          variant="ghost"
          external
        >
          Monitoring eBPF-based metrics
        </Button>
        <Button
          href="https://www.redhat.com/en/blog/automating-performance-analysis"
          variant="ghost"
          external
        >
          Automating performance analysis
        </Button>
        <Button
          href="https://www.redhat.com/en/blog/automate-performance-metrics-collection-and-visualization-rhel-system-roles"
          variant="ghost"
          external
        >
          Ansible Metrics Role
        </Button>
        <Button
          href="https://www.redhat.com/en/blog/understanding-performance-your-own-applications-rhel-its-easy-pcp"
          variant="ghost"
          external
        >
          Application Performance and OpenMetrics
        </Button>
      </div>
    </div>
  </section>

  <!-- Videos Section -->
  <section class="py-16 px-4">
    <div class="container mx-auto max-w-6xl">
      <h2 class="text-4xl font-bold mb-12 text-center text-white">Videos</h2>

      <div class="space-y-8">
        <!-- Video: Ansible Metrics Role -->
        <div class="flex flex-col md:flex-row gap-6 items-start">
          <a href="https://youtu.be/Jnnz5rnzefc" class="flex-shrink-0" target="_blank" rel="noopener">
            <img
              src="/images/ansible-metrics-role.jpg"
              alt="Ansible 'metrics' Role"
              class="w-full md:w-48 rounded border border-instrument hover:border-data transition-colors"
            />
          </a>
          <div class="flex-1">
            <p class="text-lg text-gray-200">Ansible 'metrics' Role</p>
          </div>
        </div>

        <!-- Video: Practical PCP and Grafana -->
        <div class="flex flex-col md:flex-row gap-6 items-start">
          <a href="https://www.youtube.com/watch?v=fTWAn1K7eQQ" class="flex-shrink-0" target="_blank" rel="noopener">
            <img
              src="/images/practical-pcp-grafana.jpg"
              alt="Practical Performance Co-Pilot and Grafana"
              class="w-full md:w-48 rounded border border-instrument hover:border-data transition-colors"
            />
          </a>
          <div class="flex-1">
            <p class="text-lg text-gray-200">Practical Performance Co-Pilot and Grafana</p>
          </div>
        </div>

        <!-- Video: PCP and Vector -->
        <div class="flex flex-col md:flex-row gap-6 items-start">
          <a href="https://www.youtube.com/watch?v=4Dt_VDFLDnw" class="flex-shrink-0" target="_blank" rel="noopener">
            <img
              src="/images/pcp-vector-demo.jpg"
              alt="PCP and Vector new features"
              class="w-full md:w-48 rounded border border-instrument hover:border-data transition-colors"
            />
          </a>
          <div class="flex-1">
            <p class="text-lg text-gray-200">Performance Co-Pilot and Vector new features in RHEL-8.0</p>
          </div>
        </div>

        <!-- Video: Exploratory Performance Analysis -->
        <div class="flex flex-col md:flex-row gap-6 items-start">
          <a href="https://www.youtube.com/watch?v=zrAjevr8_Ds" class="flex-shrink-0" target="_blank" rel="noopener">
            <img
              src="/images/video-exploratory-perf-analysis.jpg"
              alt="Exploratory Performance Analysis"
              class="w-full md:w-48 rounded border border-instrument hover:border-data transition-colors"
            />
          </a>
          <div class="flex-1">
            <p class="text-lg text-gray-200">Exploratory Performance Analysis with Performance Co-Pilot</p>
          </div>
        </div>

        <!-- Video: Storage Performance -->
        <div class="flex flex-col md:flex-row gap-6 items-start">
          <a href="https://www.youtube.com/watch?v=Ip3ITBUAcjU" class="flex-shrink-0" target="_blank" rel="noopener">
            <img
              src="/images/storage-performance-pcp.jpg"
              alt="Evaluating Storage Performance"
              class="w-full md:w-48 rounded border border-instrument hover:border-data transition-colors"
            />
          </a>
          <div class="flex-1">
            <p class="text-lg text-gray-200">Evaluating Red Hat Storage Performance using Performance Co-Pilot</p>
          </div>
        </div>

        <!-- Video: Programming PCP -->
        <div class="flex flex-col md:flex-row gap-6 items-start">
          <a href="https://www.youtube.com/watch?v=749lE2zjz3I" class="flex-shrink-0" target="_blank" rel="noopener">
            <img
              src="/images/programming-pcp-toolkit.jpg"
              alt="Programming PCP toolkit"
              class="w-full md:w-48 rounded border border-instrument hover:border-data transition-colors"
            />
          </a>
          <div class="flex-1">
            <p class="text-lg text-gray-200">Programming the Performance Co-Pilot toolkit</p>
          </div>
        </div>

        <!-- Video: Regression Analysis -->
        <div class="flex flex-col md:flex-row gap-6 items-start">
          <a href="https://www.youtube.com/watch?v=Z9fSymDfuvQ" class="flex-shrink-0" target="_blank" rel="noopener">
            <img
              src="/images/regression-analysis-pcp.jpg"
              alt="Regression Analysis with PCP"
              class="w-full md:w-48 rounded border border-instrument hover:border-data transition-colors"
            />
          </a>
          <div class="flex-1">
            <p class="text-lg text-gray-200">Regression Analysis with Performance Co-Pilot</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
